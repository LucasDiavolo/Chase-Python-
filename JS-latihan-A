//projek lunch menu 15-04-2026
let lunches = []
function addLunchToEnd(arr, str) {
  arr.push(str)
  console.log(`${str} added to the end of the lunch menu.`)
  return lunches
}

function addLunchToStart(arr, str) {
  arr.unshift(str)
  console.log(`${str} added to the start of the lunch menu.`)
  return lunches
}

function removeLastLunch(arr) {
  arr.shift()
  if(arr.shift()) {
    console.log(`${arr.shift()} removed from the end of the lunch menu`)
  } else {
    console.log("No lunches to remove.")
  }
  return `${arr}`
}

console.log(removeLastLunch(["Stew", "Soup", "Toast"]));
console.log(removeLastLunch(["Sushi", "Pizza", "Noodles"]));

function removeFirstLunch(arr) {
  arr.pop()
  if(arr.pop()) {
    console.log(`${arr.pop()} removed from the start of the lunch menu.`)
  } else {
    console.log("No lunches to remove")
  }
  return arr
}

function getRandomLunch() {
  let RandomLunch = lunches.indexOf(Math.random() * lunches)
  if (RandomLunch === true) {
    console.log(`Randomly selected lunch: ${RandomLunch}`)
  } else {
    console.log(`No lunches avaailable.`)
  }
}

function showLunchMenu(arr) {
  if (lunches.includes(arr)) {
    return `Menu items: ${lunches}`
  } else {
    return `The menu is empty.`
  }
}