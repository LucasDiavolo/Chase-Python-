console.log(checkAccess("Murasame"));

//projek lunch menu 15-04-2026
let lunches = []
function addLunchToEnd(arr, str) {
  arr.push(str)
  console.log(`${str} added to the end of the lunch menu.`)
  return arr
}

function addLunchToStart(arr, str) {
  arr.unshift(str)
  console.log(`${str} added to the start of the lunch menu.`)
  return arr
}

function removeLastLunch(arr) {
  let remove = arr.shift()
  if(remove) {
    console.log(`${remove} removed from the end of the lunch menu`)
  } else {
    console.log("No lunches to remove.")
  }
  return arr
}

console.log(removeLastLunch(["Stew", "Soup", "Toast"]));
console.log(removeLastLunch(["Sushi", "Pizza", "Noodles"]));

function removeFirstLunch(arr) {
  let firstLunch = arr.pop()
  if(firstLunch) {
    console.log(`${firstLunch} removed from the start of the lunch menu.`)
  } else {
    console.log("No lunches to remove")
  }
  return arr
}

console.log(removeFirstLunch(["Salad", "Eggs", "Cheese"]));

function getRandomLunch(arr) {
  let RandomLunch = Math.floor(Math.random() * arr.length)
  if (RandomLunch >= 0) {
    return `Randomly selected lunch: ${arr[RandomLunch]}`
  } else {
    return `No lunches available.`
  };
}

console.log(getRandomLunch(["Apples", "Blueberries", "Pineapple"]))

function showLunchMenu(arr) {
  if (arr.length > 0) {
    return `Menu items: ${arr}`
  } else {
    return `The menu is empty.`
  }
}

console.log(showLunchMenu([]))

