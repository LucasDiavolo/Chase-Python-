const readline = require('readline')
const rl = readline.createInterface({input: process.stdin, output: process.stdout})

let systemConfig = {
    systemName: "NIDS v1.0",
    version: 1.0,
    isActive: true,
    maxAttempts: 3,
    blockedIPs: [],
    alertLog: []
}

const threatDatabase = {
    PortScan : {
        severity: "HIGH",
        port: 0,
        description: "Port telah dilakukan scanning",
        autoBlock: false
    },
    BruteForce: {
        severity: "CRITICAL",
        port: 22,
        description: "Terdapat penyerangan secara brutal",
        autoBlock: true
    },
    SQLInjection: {
        severity: "CRITICAL",
        port: 3306,
        description: "Terdapat script injeksi SQL",
        autoBlock: true
    },
    DDoS: {
        severity: "HIGH",
        port: 80,
        description: "Penyerangan DDoS",
        autoBlock: false
    }
}

function displayBanner() {
    console.log(`
╔════════════════════════════════════════╗
║   "NETWORK INTRUSION DETECTION SYSTEM" ║
║   ${systemConfig.systemName} | Version ${systemConfig.version}                ║
║   Status: ACTIVE                       ║
╚════════════════════════════════════════╝
`)
}

displayBanner()

function blockIP(ipAddress) {
    let status = systemConfig.blockedIPs.includes(ipAddress) ? `⚠️ IP sudah diblokir sebelumnya` : ((systemConfig.push(ipAddress), `🚫 IP berhasil diblokir`)
    console.log(status);
}

function createAlert(ipAddress, threatType, severity) {
    const alert = {
        id: systemConfig.alertlog + 1,
        timestamp: new Date().toLocaleString(),
        ip: ipAddress,
        threat: threatType,
        severity: severity,
        resolved: false
    }
    systemConfig.alertLog.push(alert)
    return alert
}

function analyzeThreat(ipAddress, threatType) {
    if (threatDatabase[threatType]) {
       let threat = threatDatabase[threatType]
    } else {
        return "❓ Threat type tidak dikenali"
    }
    createAlert(ipAddress, threatType, severity)
    switch (threat.severity) {
        case "CRITICAL":
            console.log("🔴 CRITICAL ALERT!") 
            break;
        case "HIGH":
            console.log("🟠 HIGH ALERT!")
            break;
        case "MEDIUM":
            console.log("🟡 MEDIUM ALERT!")
            break;
        default: 
            console.log("🟢 LOW - Monitoring only")
    }
    console.log(`
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
📡 IP Address  : ${ipAddress}
⚠️  Threat      : ${threatType}
🔌 Port        : ${threat.port}
📝 Description : ${threat.description}
🕐 Timestamp   : ${alert.timestamp}
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
`)
    if (threat.autoBlock === true) {
        blockIP(ipAddress);
    }
}

function showStatus() {
    console.log(`${systemConfig.alertlog.length}`)
    console.log(`${systemConfig.blockedIPs.length}`)
    const status = systemConfig.alertLog.length > 0 ? `⚠️ Sistem mendeteksi ancaman aktif` : `✅ Sistem aman, tidak ada ancaman terdeteksi`
    console.log(status)
    console.log(blockedIPs.forEach())
}

function showMenu() {
    rl.question(`
 ╔══════════════════════════════╗
║         MAIN MENU            ║
║  1. Analyze Threat           ║
║  2. Block IP Manual          ║
║  3. Show System Status       ║
║  4. Exit                     ║
╚══════════════════════════════╝
Pilih menu (1-4): `, function(choice)
    )
}

function handleMenu(choice) {
    switch (choice) {
        case "1":
            rl.question("Masukkan IP Address", function(ipAddress) {
              rl.question("Masukkan tipe ancaman", function(threatType) {
                analyzeThreat(ipAddress, threatType)
                showMenu()
  }
}
            break;
        case "2": 
            rl.question("Masukkan IP Address", ipAddress)
            blockIP(ipAddress)
            showMenu()
            break;
        case "3":
            showStatus()
            showMenu()
            break;
        case "4":
            console.log("👋 Sistem NIDS dimatikan. Stay secure!")
            rl.close()
            break;
        default:
            console.log("❌ Pilihan tidak valid!")
            showMenu()
 }
}
displayBanner()
showMenu()
