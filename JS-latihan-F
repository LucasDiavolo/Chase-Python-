let count = 2
function cardCounter(card) {
  let decision;
  if (count >= 0) {
    decision = "Bet"
  } else {
    decision = "Hold"
  };

  if (
    card === 2 ||
    card === 3 ||
    card === 4 || 
    card === 5 ||
    card === 6 
  ) {
    count++;
  } else if (
    card === 10 ||
    card === "J" ||
    card === "K" ||
    card === "A"
  ) {
    count--;
  };

  return count + " " + decision
}

