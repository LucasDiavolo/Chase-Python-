//contoh function maskEmail menggunakan metode replace, slice, repeat, length
let email = "apple.pie@example.com"

function maskEmail(email) {
  let masked = email.slice(1, email.indexOf('@') - 1)
  let masked2 = email.replace(masked, "*".repeat(masked.length))
  return masked2
}

console.log(maskEmail(email));

