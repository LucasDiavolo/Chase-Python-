function isLeapYear(year) {
  const yearDivisible1 = year % 4;
  const yearDivisible2 = year % 100;
  const yearDivisible3 = year % 400;

  if (yearDivisible1 === 0 && yearDivisible2 === 0 && yearDivisible3 === 0) {
    console.log(`${year} is a leap year.`)
  } else if (yearDivisible1 === 0 && yearDivisible2 === 0) {
    console.log(`${year} is not a leap year.`)
  } else if (yearDivisible1 === 0) {
    console.log(`${year} is a leap year.`)
  };
}

let year = 2020;

const result = isLeapYear(year);
console.log(result);
