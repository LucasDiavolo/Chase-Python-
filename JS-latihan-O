function normalizeUnits(manifest) {
    let cargo = {...manifest}
    if (cargo.unit !== "kg") {
        cargo.weight = cargo.weight * 0.45
        cargo.unit = "kg"
    } 
    return cargo.weight
};

console.log(normalizeUnits({
  containerId: 1,
  destination: "Monterey, California, USA",
  weight: 831,
  unit: "lb",
  hazmat: false
}));

function validateManifest(manifest) {
    let cargo = {...manifest}
    if (
      typeof cargo.containerId === "number" && cargo.containerId > 0 &&
      typeof cargo.destination === "string" && cargo.destination !== undefined && 
      cargo.destination !== "Missing" || "Invalid" &&
      typeof cargo.weight === "number" && cargo.weight > 0 &&
      cargo.unit === "lb" || cargo.unit === "kg" &&
      typeof cargo.hazmat === "boolean"
    ) {
      return {}
    } else {
      return "false"
    }
}
